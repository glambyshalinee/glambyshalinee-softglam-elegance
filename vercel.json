{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "server/index.mjs": {
      "runtime": "nodejs24.x"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/client/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/server/index.mjs"
    }
  ]
}
